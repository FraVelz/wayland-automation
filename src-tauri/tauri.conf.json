{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wayland Automation",
  "version": "0.1.0",
  "identifier": "com.wayland.automation",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wayland Automation",
        "width": 900,
        "height": 760,
        "minWidth": 780,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
