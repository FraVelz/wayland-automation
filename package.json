{
  "name": "wayland-automation",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm exec vite",
    "build": "tsc -b && pnpm exec vite build",
    "preview": "pnpm exec vite preview",
    "tauri": "tauri",
    "lint": "eslint . && tsc -b --noEmit",
    "react:doctor": "react-doctor . --full --verbose",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\" \"!env/**\" \"!.cursor/**\" \"!.build/**\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,js,ts}\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tauri-apps/cli": "^2.2.7",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "markdownlint-cli2": "^0.17.2",
    "postcss": "^8.5.3",
    "prettier": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react-doctor": "^0.2.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0"
  }
}
